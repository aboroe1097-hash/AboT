{
  "name": "abot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cli": "tsx apps/cli/src/index.ts",
    "dev": "tsx apps/server/src/index.ts",
    "server": "tsx apps/server/src/index.ts",
    "workspace:init": "tsx apps/cli/src/workspace-init.ts",
    "opencode:hook": "tsx apps/cli/src/opencode-hook.ts",
    "test:api": "tsx apps/cli/src/check-api.ts",
    "test:router": "tsx apps/cli/src/check-router-examples.ts",
    "qa": "npm run typecheck && npm run test:router && npm run test:api",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
