{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@abot/agents": ["packages/agents/src/index.ts"],
      "@abot/context": ["packages/context/src/index.ts"],
      "@abot/core": ["packages/core/src/index.ts"],
      "@abot/memory": ["packages/memory/src/index.ts"],
      "@abot/router": ["packages/router/src/index.ts"],
      "@abot/server": ["apps/server/src/server.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts"
  ]
}
