ABOT_ROUTER_PROVIDER=openai-compatible
ABOT_ROUTER_BASE_URL=https://your-openai-compatible-provider.example/v1
ABOT_ROUTER_API_KEY=replace-with-your-local-key
ABOT_ROUTER_MODEL=deepseek-v4-flash
ABOT_ROUTER_TIMEOUT_MS=6000
ABOT_OPENAGENT_CONFIG=C:\Users\you\.config\opencode\oh-my-openagent.json
# Optional, only if you want AboT to call opencode-go models directly:
# OPENCODE_GO_BASE_URL=http://127.0.0.1:11434/v1
# OPENCODE_GO_API_KEY=optional-local-key
